{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "guild-engine/project.schema.json",
  "version": "0.1.0",
  "title": "Guild Engine Project Schema",
  "description": "Defines all node types, field shapes, and connection rules for a guild-engine project.json.",

  "definitions": {

    "rarity": {
      "type": "string",
      "enum": ["common", "uncommon", "rare", "epic", "legendary"]
    },

    "slot": {
      "type": "string",
      "enum": ["weapon", "armor", "accessory", "relic"]
    },

    "stat_block": {
      "type": "object",
      "description": "Flat key-value map of stat name to numeric modifier.",
      "additionalProperties": { "type": "number" },
      "examples": [{ "attack": 5, "defense": 2, "speed": -1 }]
    },

    "cost": {
      "type": "array",
      "description": "List of resource amounts required to perform an action.",
      "items": {
        "type": "object",
        "required": ["resource_id", "amount"],
        "properties": {
          "resource_id": { "type": "string" },
          "amount": { "type": "number", "minimum": 0 }
        }
      }
    },

    "unlock_condition": {
      "type": "object",
      "description": "A single condition that must be true for something to become available.",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["resource_gte", "building_level", "act_reached", "faction_rep_gte", "upgrade_owned", "hero_count_gte", "prestige_count_gte"]
        },
        "target_id": { "type": "string", "description": "ID of the referenced node." },
        "value": { "type": "number" }
      }
    },

    "loot_entry": {
      "type": "object",
      "required": ["item_id", "weight"],
      "properties": {
        "item_id": { "type": "string", "description": "References an item node id." },
        "weight": { "type": "number", "minimum": 1, "description": "Relative drop weight. Higher = more common." },
        "min_qty": { "type": "integer", "minimum": 1, "default": 1 },
        "max_qty": { "type": "integer", "minimum": 1, "default": 1 },
        "guaranteed": { "type": "boolean", "default": false, "description": "If true, always drops regardless of roll." }
      }
    },

    "expedition_event": {
      "type": "object",
      "description": "A mid-run random event that fires during an expedition countdown.",
      "required": ["id", "label", "trigger_chance", "choices"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string", "description": "Short description shown in the event log." },
        "trigger_chance": { "type": "number", "minimum": 0, "maximum": 1, "description": "0.0–1.0 probability this event fires per tick." },
        "condition": { "$ref": "#/definitions/unlock_condition" },
        "choices": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "type": "object",
            "required": ["label", "outcome"],
            "properties": {
              "label": { "type": "string" },
              "outcome": {
                "type": "object",
                "properties": {
                  "resource_delta": { "$ref": "#/definitions/stat_block" },
                  "hero_status": { "type": "string", "enum": ["injured", "inspired", "cursed", "none"] },
                  "loot_table_id": { "type": "string" },
                  "log_message": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },

    "boss_phase": {
      "type": "object",
      "required": ["phase_number", "hp_threshold", "label"],
      "properties": {
        "phase_number": { "type": "integer", "minimum": 1 },
        "hp_threshold": { "type": "number", "minimum": 0, "maximum": 1, "description": "Phase activates when boss HP drops below this fraction (0.0–1.0)." },
        "label": { "type": "string" },
        "modifier": { "$ref": "#/definitions/stat_block", "description": "Stat changes applied to boss in this phase." },
        "event_id": { "type": "string", "description": "Optional expedition_event fired on phase transition." },
        "log_message": { "type": "string" }
      }
    },

    "canvas_position": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    }
  },

  "properties": {

    "meta": {
      "type": "object",
      "required": ["schema_version", "title", "author"],
      "properties": {
        "schema_version": { "type": "string", "const": "0.1.0" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "description": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },

    "nodes": {
      "type": "array",
      "description": "All authored nodes in the project graph.",
      "items": {
        "oneOf": [

          {
            "title": "Resource",
            "description": "A tracked quantity in the game economy (gold, wood, mana, etc.).",
            "required": ["id", "type", "label", "base_cap", "base_income"],
            "properties": {
              "id":          { "type": "string" },
              "type":        { "type": "string", "const": "resource" },
              "label":       { "type": "string" },
              "description": { "type": "string" },
              "icon":        { "type": "string", "description": "Emoji or asset filename." },
              "base_cap":    { "type": "number", "minimum": 0, "description": "Starting storage cap. 0 = unlimited." },
              "base_income": { "type": "number", "description": "Passive gain per second at game start." },
              "is_material": { "type": "boolean", "default": false, "description": "If true, used as crafting material rather than displayed as a primary resource." },
              "canvas_pos":  { "$ref": "#/definitions/canvas_position" },
              "connections": {
                "type": "array",
                "description": "Allowed: building (produces this), recipe (consumes/produces), upgrade (modifies cap/income).",
                "items": { "type": "string" }
              }
            }
          },

          {
            "title": "Item",
            "description": "A discrete object — either equipment for heroes or a crafting material.",
            "required": ["id", "type", "label", "subtype", "rarity"],
            "properties": {
              "id":          { "type": "string" },
              "type":        { "type": "string", "const": "item" },
              "label":       { "type": "string" },
              "description": { "type": "string" },
              "icon":        { "type": "string" },
              "rarity":      { "$ref": "#/definitions/rarity" },
              "subtype": {
                "type": "string",
                "enum": ["equipment", "material"],
                "description": "Equipment goes on heroes; material is consumed by recipes."
              },
              "slot": {
                "$ref": "#/definitions/slot",
                "description": "Required when subtype = equipment."
              },
              "stat_modifiers": {
                "$ref": "#/definitions/stat_block",
                "description": "Stat changes granted when equipped. Only for equipment."
              },
              "stack_limit": { "type": "integer", "minimum": 1, "default": 1, "description": "Max stack size in inventory. Use 99 for materials." },
              "canvas_pos":  { "$ref": "#/definitions/canvas_position" },
              "connections": {
                "type": "array",
                "description": "Allowed: loot_table (drops from), recipe (ingredient or output).",
                "items": { "type": "string" }
              }
            }
          },

          {
            "title": "Loot table",
            "description": "A weighted drop pool referenced by expeditions, bosses, and buildings.",
            "required": ["id", "type", "label", "rolls", "entries"],
            "properties": {
              "id":     { "type": "string" },
              "type":   { "type": "string", "const": "loot_table" },
              "label":  { "type": "string" },
              "rolls":  { "type": "integer", "minimum": 1, "description": "Number of independent rolls per drop event." },
              "entries": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/definitions/loot_entry" }
              },
              "canvas_pos":  { "$ref": "#/definitions/canvas_position" },
              "connections": {
                "type": "array",
                "description": "Allowed: expedition, boss_expedition, building (chest/shop source).",
                "items": { "type": "string" }
              }
            }
          },

          {
            "title": "Recipe",
            "description": "A crafting formula — inputs consumed, output produced, tied to a building.",
            "required": ["id", "type", "label", "inputs", "output_item_id", "output_qty", "craft_time_s"],
            "properties": {
              "id":             { "type": "string" },
              "type":           { "type": "string", "const": "recipe" },
              "label":          { "type": "string" },
              "inputs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["item_id", "qty"],
                  "properties": {
                    "item_id": { "type": "string" },
                    "qty":     { "type": "integer", "minimum": 1 }
                  }
                }
              },
              "output_item_id": { "type": "string" },
              "output_qty":     { "type": "integer", "minimum": 1, "default": 1 },
              "craft_time_s":   { "type": "number", "minimum": 0, "description": "Seconds to complete one craft. 0 = instant." },
              "unlock_conditions": {
                "type": "array",
                "items": { "$ref": "#/definitions/unlock_condition" }
              },
              "canvas_pos":  { "$ref": "#/definitions/canvas_position" },
              "connections": {
                "type": "array",
                "description": "Allowed: building (station that runs this recipe), item (inputs/output).",
                "items": { "type": "string" }
              }
            }
          },

          {
            "title": "Hero class",
            "description": "A class template from which hero instances are generated.",
            "required": ["id", "type", "label", "base_stats", "slots"],
            "properties": {
              "id":          { "type": "string" },
              "type":        { "type": "string", "const": "hero_class" },
              "label":       { "type": "string" },
              "description": { "type": "string" },
              "icon":        { "type": "string" },
              "base_stats":  { "$ref": "#/definitions/stat_block", "description": "attack, defense, speed, hp, luck." },
              "stat_growth": { "$ref": "#/definitions/stat_block", "description": "Stat increase per level." },
              "slots": {
                "type": "array",
                "items": { "$ref": "#/definitions/slot" },
                "description": "Equipment slots this class can use."
              },
              "recruit_cost": { "$ref": "#/definitions/cost" },
              "unlock_conditions": {
                "type": "array",
                "items": { "$ref": "#/definitions/unlock_condition" }
              },
              "canvas_pos":  { "$ref": "#/definitions/canvas_position" },
              "connections": {
                "type": "array",
                "description": "Allowed: ability (abilities this class can learn), building (training location), expedition.",
                "items": { "type": "string" }
              }
            }
          },

          {
            "title": "Ability",
            "description": "An active or passive skill attached to a hero class.",
            "required": ["id", "type", "label", "trigger", "effect"],
            "properties": {
              "id":          { "type": "string" },
              "type":        { "type": "string", "const": "ability" },
              "label":       { "type": "string" },
              "description": { "type": "string" },
              "icon":        { "type": "string" },
              "trigger": {
                "type": "string",
                "enum": ["passive", "on_combat_start", "on_hit", "on_kill", "on_expedition_complete", "on_status_applied"]
              },
              "effect": {
                "type": "object",
                "properties": {
                  "stat_modifier":   { "$ref": "#/definitions/stat_block" },
                  "resource_delta":  { "$ref": "#/definitions/stat_block" },
                  "apply_status":    { "type": "string", "enum": ["injured", "inspired", "cursed"] },
                  "loot_bonus_pct":  { "type": "number", "description": "Percentage bonus to loot roll weights." },
                  "success_bonus":   { "type": "number", "description": "Flat addition to expedition success chance (0.0–1.0)." }
                }
              },
              "unlock_level": { "type": "integer", "minimum": 1, "default": 1 },
              "canvas_pos":  { "$ref": "#/definitions/canvas_position" },
              "connections": {
                "type": "array",
                "description": "Allowed: hero_class (owner).",
                "items": { "type": "string" }
              }
            }
          },

          {
            "title": "Building",
            "description": "A structure the player builds. May produce resources, assign heroes, host crafting recipes, or unlock content.",
            "required": ["id", "type", "label", "max_level", "levels"],
            "properties": {
              "id":          { "type": "string" },
              "type":        { "type": "string", "const": "building" },
              "label":       { "type": "string" },
              "description": { "type": "string" },
              "icon":        { "type": "string" },
              "max_level":   { "type": "integer", "minimum": 1 },
              "levels": {
                "type": "array",
                "description": "One entry per level (index 0 = level 1).",
                "items": {
                  "type": "object",
                  "required": ["build_cost"],
                  "properties": {
                    "build_cost":      { "$ref": "#/definitions/cost" },
                    "build_time_s":    { "type": "number", "minimum": 0 },
                    "production":      { "$ref": "#/definitions/stat_block", "description": "Resource id → per-second production at this level." },
                    "hero_slots":      { "type": "integer", "minimum": 0, "default": 0 },
                    "recipe_slots":    { "type": "integer", "minimum": 0, "default": 0, "description": "Concurrent crafting queue length." },
                    "unlock_node_ids": { "type": "array", "items": { "type": "string" }, "description": "Node IDs that become visible when this level is reached." }
                  }
                }
              },
              "is_crafting_station": { "type": "boolean", "default": false },
              "loot_table_id": { "type": "string", "description": "Optional: building generates loot (shop/chest)." },
              "unlock_conditions": {
                "type": "array",
                "items": { "$ref": "#/definitions/unlock_condition" }
              },
              "canvas_pos":  { "$ref": "#/definitions/canvas_position" },
              "connections": {
                "type": "array",
                "description": "Allowed: resource (produces), recipe (hosts), loot_table (shop), upgrade (enhances), act (gated by).",
                "items": { "type": "string" }
              }
            }
          },

          {
            "title": "Upgrade",
            "description": "A one-time or tiered purchase that modifies game systems.",
            "required": ["id", "type", "label", "cost", "effect"],
            "properties": {
              "id":          { "type": "string" },
              "type":        { "type": "string", "const": "upgrade" },
              "label":       { "type": "string" },
              "description": { "type": "string" },
              "icon":        { "type": "string" },
              "cost":        { "$ref": "#/definitions/cost" },
              "max_tier":    { "type": "integer", "minimum": 1, "default": 1, "description": "1 = one-time purchase. >1 = tiered upgrade." },
              "effect": {
                "type": "object",
                "properties": {
                  "resource_cap_multiplier":    { "$ref": "#/definitions/stat_block" },
                  "resource_income_multiplier": { "$ref": "#/definitions/stat_block" },
                  "hero_stat_modifier":         { "$ref": "#/definitions/stat_block" },
                  "expedition_success_bonus":   { "type": "number" },
                  "craft_speed_multiplier":     { "type": "number" },
                  "loot_bonus_pct":             { "type": "number" },
                  "unlock_node_ids":            { "type": "array", "items": { "type": "string" } }
                }
              },
              "unlock_conditions": {
                "type": "array",
                "items": { "$ref": "#/definitions/unlock_condition" }
              },
              "canvas_pos":  { "$ref": "#/definitions/canvas_position" },
              "connections": {
                "type": "array",
                "description": "Allowed: resource, building, hero_class, expedition (what this upgrade affects).",
                "items": { "type": "string" }
              }
            }
          },

          {
            "title": "Expedition",
            "description": "A standard timed run. Heroes are sent, events fire, loot drops on completion.",
            "required": ["id", "type", "label", "duration_s", "party_size", "level", "loot_table_id"],
            "properties": {
              "id":                   { "type": "string" },
              "type":                 { "type": "string", "const": "expedition" },
              "label":                { "type": "string" },
              "description":          { "type": "string" },
              "icon":                 { "type": "string" },
              "duration_s":           { "type": "number", "minimum": 1, "description": "Countdown length in seconds." },
              "party_size":           { "type": "integer", "minimum": 1, "maximum": 6 },
              "level":                { "type": "integer", "minimum": 1, "maximum": 20, "description": "Expedition difficulty level used for power checks and XP." },
              "enemy_atk":            { "type": "number", "default": 10, "description": "Burst damage checked against the party HP floor." },
              "enemy_hp":             { "type": "number", "default": 100, "description": "Enemy HP pool used for the DPS check." },
              "base_xp":              { "type": ["number", "null"], "default": null, "description": "Null = auto (level * 15). 0 = explicit zero XP." },
              "curse_chance":         { "type": "number", "minimum": 0, "maximum": 1, "default": 0 },
              "resource_rewards": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["resource_id", "amount", "on"],
                  "properties": {
                    "resource_id": { "type": "string" },
                    "amount": { "type": "number" },
                    "on": { "type": "string", "enum": ["any", "success", "dominant"], "default": "success" }
                  }
                }
              },
              "faction_rewards": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["faction_id", "rep", "on"],
                  "properties": {
                    "faction_id": { "type": "string" },
                    "rep": { "type": "number" },
                    "on": { "type": "string", "enum": ["any", "success", "dominant"], "default": "success" }
                  }
                }
              },
              "on_success_unlock": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Node IDs that become visible on success."
              },
              "loot_table_id":        { "type": "string" },
              "fail_loot_table_id":   { "type": "string", "description": "Optional: consolation loot on failure." },
              "entry_cost":           { "$ref": "#/definitions/cost" },
              "events": {
                "type": "array",
                "items": { "$ref": "#/definitions/expedition_event" },
                "description": "Mid-run events that can fire during the countdown."
              },
              "recommended_stats":    { "$ref": "#/definitions/stat_block", "description": "Shown to player as difficulty guidance." },
              "unlock_conditions": {
                "type": "array",
                "items": { "$ref": "#/definitions/unlock_condition" }
              },
              "canvas_pos":  { "$ref": "#/definitions/canvas_position" },
              "connections": {
                "type": "array",
                "description": "Allowed: loot_table, act (gated by), hero_class (preferred classes), upgrade.",
                "items": { "type": "string" }
              }
            }
          },

          {
            "title": "Boss expedition",
            "description": "A multi-phase boss fight with an HP bar, phase transitions, and unique guaranteed loot.",
            "required": ["id", "type", "label", "duration_s", "party_size", "boss_hp", "phases", "loot_table_id"],
            "properties": {
              "id":             { "type": "string" },
              "type":           { "type": "string", "const": "boss_expedition" },
              "label":          { "type": "string" },
              "description":    { "type": "string" },
              "icon":           { "type": "string" },
              "duration_s":     { "type": "number", "minimum": 1 },
              "party_size":     { "type": "integer", "minimum": 1, "maximum": 6 },
              "boss_hp":        { "type": "number", "minimum": 1 },
              "boss_stats":     { "$ref": "#/definitions/stat_block" },
              "phases": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/definitions/boss_phase" }
              },
              "loot_table_id":          { "type": "string", "description": "Guaranteed loot on kill." },
              "fail_loot_table_id":     { "type": "string" },
              "entry_cost":             { "$ref": "#/definitions/cost" },
              "repeatable":             { "type": "boolean", "default": false },
              "unlock_conditions": {
                "type": "array",
                "items": { "$ref": "#/definitions/unlock_condition" }
              },
              "canvas_pos":  { "$ref": "#/definitions/canvas_position" },
              "connections": {
                "type": "array",
                "description": "Allowed: loot_table, act, hero_class.",
                "items": { "type": "string" }
              }
            }
          },

          {
            "title": "Act",
            "description": "A story chapter. Gates content behind world-state progression milestones.",
            "required": ["id", "type", "label", "act_number", "completion_conditions"],
            "properties": {
              "id":                     { "type": "string" },
              "type":                   { "type": "string", "const": "act" },
              "label":                  { "type": "string" },
              "description":            { "type": "string" },
              "act_number":             { "type": "integer", "minimum": 1 },
              "completion_conditions": {
                "type": "array",
                "items": { "$ref": "#/definitions/unlock_condition" },
                "description": "All conditions must be true for the act to complete."
              },
              "expedition_ids":         { "type": "array", "items": { "type": "string" }, "description": "Expedition node IDs owned by this act." },
              "boss_expedition_id":     { "type": "string", "description": "Boss expedition node ID owned by this act." },
              "on_complete_events":     { "type": "array", "items": { "type": "string" }, "description": "event node IDs fired on act completion." },
              "unlocks_node_ids":       { "type": "array", "items": { "type": "string" } },
              "narrative_log":          { "type": "string", "description": "Flavour text shown in the event log on act start/complete." },
              "canvas_pos":  { "$ref": "#/definitions/canvas_position" },
              "connections": {
                "type": "array",
                "description": "Allowed: event (fires on complete), building, expedition, boss_expedition (unlocks).",
                "items": { "type": "string" }
              }
            }
          },

          {
            "title": "Event",
            "description": "A narrative or world-state event triggered by acts, buildings, or factions.",
            "required": ["id", "type", "label"],
            "properties": {
              "id":          { "type": "string" },
              "type":        { "type": "string", "const": "event" },
              "label":       { "type": "string" },
              "description": { "type": "string" },
              "log_message": { "type": "string", "description": "Text shown in the expedition/world event log." },
              "choices": {
                "type": "array",
                "maxItems": 4,
                "items": {
                  "type": "object",
                  "required": ["label", "outcome"],
                  "properties": {
                    "label":   { "type": "string" },
                    "outcome": {
                      "type": "object",
                      "properties": {
                        "resource_delta":   { "$ref": "#/definitions/stat_block" },
                        "unlock_node_ids":  { "type": "array", "items": { "type": "string" } },
                        "faction_rep_delta":{ "$ref": "#/definitions/stat_block" },
                        "log_message":      { "type": "string" }
                      }
                    }
                  }
                }
              },
              "canvas_pos":  { "$ref": "#/definitions/canvas_position" },
              "connections": {
                "type": "array",
                "description": "Allowed: act (triggered by), faction (affects rep).",
                "items": { "type": "string" }
              }
            }
          },

          {
            "title": "Faction",
            "description": "A named group with a reputation meter. Reputation gates vendors, story branches, and upgrades.",
            "required": ["id", "type", "label", "rep_tiers"],
            "properties": {
              "id":          { "type": "string" },
              "type":        { "type": "string", "const": "faction" },
              "label":       { "type": "string" },
              "description": { "type": "string" },
              "icon":        { "type": "string" },
              "rep_tiers": {
                "type": "array",
                "description": "Ordered list of reputation thresholds and what they unlock.",
                "items": {
                  "type": "object",
                  "required": ["threshold", "label"],
                  "properties": {
                    "threshold":       { "type": "number", "description": "Minimum rep value to reach this tier." },
                    "label":           { "type": "string", "description": "Tier name, e.g. Neutral, Honored, Exalted." },
                    "unlock_node_ids": { "type": "array", "items": { "type": "string" } },
                    "discount_pct":    { "type": "number", "description": "Cost discount on faction-linked shop items." }
                  }
                }
              },
              "starting_rep": { "type": "number", "default": 0 },
              "canvas_pos":   { "$ref": "#/definitions/canvas_position" },
              "connections": {
                "type": "array",
                "description": "Allowed: event (modifies rep), building (faction vendor), upgrade (faction-locked).",
                "items": { "type": "string" }
              }
            }
          },

          {
            "title": "Prestige",
            "description": "Defines one prestige/rebirth layer — reset conditions, what carries over, and permanent bonuses earned.",
            "required": ["id", "type", "label", "trigger_conditions", "currency_id", "bonuses"],
            "properties": {
              "id":    { "type": "string" },
              "type":  { "type": "string", "const": "prestige" },
              "label": { "type": "string" },
              "description": { "type": "string" },
              "trigger_conditions": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/definitions/unlock_condition" },
                "description": "All must be true for prestige to become available."
              },
              "currency_id": { "type": "string", "description": "Resource id used as prestige currency (e.g. soul_shards)." },
              "currency_formula": { "type": "string", "description": "JS expression string evaluated at prestige time. Available vars: gold, act, hero_count." },
              "resets": {
                "type": "array",
                "items": { "type": "string", "enum": ["resources", "buildings", "heroes", "upgrades", "expeditions", "factions"] },
                "description": "Which categories reset on prestige. Anything not listed carries over."
              },
              "bonuses": {
                "type": "array",
                "description": "Permanent bonuses purchased with prestige currency.",
                "items": {
                  "type": "object",
                  "required": ["id", "label", "cost", "effect"],
                  "properties": {
                    "id":     { "type": "string" },
                    "label":  { "type": "string" },
                    "max_tier": { "type": "integer", "minimum": 1, "default": 1 },
                    "cost":   { "type": "number", "description": "Prestige currency cost per tier." },
                    "effect": { "$ref": "#/definitions/stat_block" }
                  }
                }
              },
              "canvas_pos":  { "$ref": "#/definitions/canvas_position" },
              "connections": {
                "type": "array",
                "description": "Allowed: resource (prestige currency), act (trigger gate).",
                "items": { "type": "string" }
              }
            }
          }

        ]
      }
    },

    "edges": {
      "type": "array",
      "description": "Directed connections between nodes, authored in the canvas.",
      "items": {
        "type": "object",
        "required": ["id", "source", "target", "relation"],
        "properties": {
          "id":       { "type": "string" },
          "source":   { "type": "string", "description": "Node id." },
          "target":   { "type": "string", "description": "Node id." },
          "relation": {
            "type": "string",
            "enum": [
              "produces",
              "consumes",
              "drops_from",
              "hosts_recipe",
              "trains",
              "unlocks",
              "gates",
              "triggers",
              "modifies",
              "preferred_class",
              "affects_rep"
            ],
            "description": "Semantic label describing why these two nodes are connected."
          }
        }
      }
    }

  },

  "required": ["meta", "nodes", "edges"],

  "x-connection-rules": {
    "description": "Enforced by the compiler. Source type → allowed target types per relation.",
    "resource":         { "produces": ["building"], "modifies": ["upgrade"] },
    "item":             { "drops_from": ["loot_table"], "consumes": ["recipe"] },
    "loot_table":       { "drops_from": ["expedition", "boss_expedition", "building"] },
    "recipe":           { "hosts_recipe": ["building"], "consumes": ["item"], "produces": ["item"] },
    "hero_class":       { "trains": ["building"], "preferred_class": ["expedition", "boss_expedition"] },
    "ability":          { "trains": ["hero_class"] },
    "building":         { "produces": ["resource"], "hosts_recipe": ["recipe"], "unlocks": ["upgrade", "expedition", "boss_expedition"], "gates": ["act"] },
    "upgrade":          { "modifies": ["resource", "building", "hero_class", "expedition"] },
    "expedition":       { "drops_from": ["loot_table"], "gates": ["act"], "triggers": ["event"] },
    "boss_expedition":  { "drops_from": ["loot_table"], "gates": ["act"], "triggers": ["event"] },
    "act":              { "unlocks": ["building", "expedition", "boss_expedition", "upgrade"], "triggers": ["event"] },
    "event":            { "affects_rep": ["faction"], "triggers": ["act"] },
    "faction":          { "gates": ["upgrade", "building", "expedition"], "affects_rep": ["event"] },
    "prestige":         { "gates": ["act"], "produces": ["resource"] }
  }
}
