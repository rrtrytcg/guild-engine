{
  "blueprint_meta": {
    "id": "blueprint-forge-system",
    "label": "Forge System",
    "description": "A broader forge graph with smelting, weapon work, armor work, and upgrade gates.",
    "requires_schema_version": "1.2.0",
    "created_at": "2026-03-29T00:00:00.000Z",
    "flavor": "fantasy",
    "complexity": "complex",
    "parameters": [
      {
        "key": "ore_resource",
        "label": "Ore Resource",
        "description": "The raw ore material (e.g. Iron Ore, Mithril Ore)",
        "type": "resource",
        "required": true,
        "injects_into": ["bp-fsys-workflow-smelt.input_rules"]
      },
      {
        "key": "ingot_resource",
        "label": "Ingot Resource",
        "description": "The smelted bar material (e.g. Iron Ingot, Mithril Bar)",
        "type": "resource",
        "required": true,
        "injects_into": ["bp-fsys-workflow-weapon.input_rules", "bp-fsys-workflow-armor.input_rules", "bp-fsys-workflow-smelt.output_rules"]
      },
      {
        "key": "weapon_item",
        "label": "Weapon Item",
        "description": "The finished weapon output (e.g. Iron Sword, Mithril Axe)",
        "type": "item",
        "required": true,
        "injects_into": ["bp-fsys-recipe-weapon.output_item_id"]
      },
      {
        "key": "armor_item",
        "label": "Armor Item",
        "description": "The finished armor output (e.g. Iron Chestplate, Mithril Helm)",
        "type": "item",
        "required": true,
        "injects_into": ["bp-fsys-recipe-armor.output_item_id"]
      }
    ]
  },
